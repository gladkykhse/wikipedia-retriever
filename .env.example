RETRIEVER_API_TOKEN=change-me-local-token

RETRIEVER_LOG_LEVEL=INFO
RETRIEVER_LOG_FILE=logs/app.log
RETRIEVER_EMBEDDING_MODEL=sentence-transformers/multi-qa-MiniLM-L6-cos-v1
RETRIEVER_USER_AGENT=WikipediaHybridSectionRetriever/0.1.0
RETRIEVER_HTTP_CONCURRENCY=8
RETRIEVER_LANG=en
RETRIEVER_MAX_BATCH_SIZE=50
RETRIEVER_MAX_QUERY_LENGTH=500
RETRIEVER_WORKERS=1
TOKENIZERS_PARALLELISM=true

# Optional CPU thread caps. Leave unset for PyTorch, BLAS, and tokenizer
# libraries to use their default/max thread behavior. Set positive integers
# only when tuning workers vs per-process threads.
# OMP_NUM_THREADS=8
# MKL_NUM_THREADS=8
# OPENBLAS_NUM_THREADS=8
# RAYON_NUM_THREADS=8

# Tools client (tools/wikipedia.py).
RETRIEVER_URL=http://127.0.0.1:8000
