# Wikipedia retriever service configuration.
# Copy to .env (which is gitignored) and fill in values.

# Required. Bearer token required on POST /retrieve.
# Generate with:  openssl rand -hex 32
RETRIEVER_API_TOKEN=

# Optional overrides (defaults shown).
# RETRIEVER_LOG_LEVEL=INFO
# RETRIEVER_LOG_FILE=/var/log/wiki/app.log
# RETRIEVER_EMBEDDING_MODEL=sentence-transformers/multi-qa-MiniLM-L6-cos-v1
# RETRIEVER_USER_AGENT=WikipediaHybridSectionRetriever
# RETRIEVER_HTTP_CONCURRENCY=8
# RETRIEVER_LANG=en
# RETRIEVER_MAX_BATCH_SIZE=50
# RETRIEVER_MAX_QUERY_LENGTH=500
